# Подключение к PostgreSQL (драйвер psycopg v3)
DATABASE_URL=postgresql+psycopg://recsys:recsys@db:5432/recsys

# Параметры API
API_TITLE=Unified Cross-Platform Hotel RecSys
TOP_K=5
RECOMPUTE_INTERVAL_HOURS=12
CACHE_TTL_HOURS=12
SQL_ECHO=false

# Для локальной отладки без сервера можно указать SQLite:
# DATABASE_URL=sqlite:///./dev.db
